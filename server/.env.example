# Postgres credentials for docker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1
POSTGRES_DB=homedesign

# Prisma Connection (points to 'homedesign_db' container when running inside docker-compose)
# For local bare-metal development (without server docker container), change 'homedesign_db' to 'localhost'
DATABASE_URL="postgresql://postgres:1@homedesign_db:5432/homedesign?schema=public"

# JWT Secret
JWT_SECRET=super_secret_jwt_key_123

# Frontend URL (for CORS and OAuth redirect)
FRONTEND_URL=http://localhost:5173

# Google OAuth Credentials (Get these from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
